# Client-side (safe to expose — RLS protects the data)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only — add these to Vercel environment variables in the Vercel dashboard,
# NOT to .env (they are server-side only and must never be in the client bundle)
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
